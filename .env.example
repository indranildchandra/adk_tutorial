# =============================================================================
# ADK Agent — Environment Configuration
# Copy this file to .env and fill in your values.
#
# Two authentication options are supported. Enable ONE of them.
# =============================================================================


# =============================================================================
# Option 1 (Default): Vertex AI
# Requires a Google Cloud project with the Vertex AI API enabled.
# Authenticate via: gcloud auth application-default login
# =============================================================================
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1


# =============================================================================
# Option 2: Gemini API Key (no Google Cloud needed)
# Get a free key at: https://aistudio.google.com/apikey
# To use this option, comment out Option 1 above and uncomment these lines.
# =============================================================================
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your_gemini_api_key_here
